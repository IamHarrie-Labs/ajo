# Solana Configuration
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Privy Configuration (Phone login + wallet)
NEXT_PUBLIC_PRIVY_APP_ID=YOUR_PRIVY_APP_ID

# Instructions:
# 1. Get Helius API key (free): https://helius.xyz/
# 2. Get Privy App ID (free): https://dashboard.privy.io/
# 3. Copy this file to .env.local
# 4. Fill in the values above
